{
  "name": "openinput",
  "version": "0.5.0-beta.3",
  "main": "dist-electron/electron/main.js",
  "description": "Open-source stream deck configuration software with a plugin architecture for any deck-style input device",
  "author": {
    "name": "Luca Tescari",
    "url": "https://github.com/lucatescari"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/lucatescari/openinput"
  },
  "homepage": "https://github.com/lucatescari/openinput",
  "license": "MIT WITH Commons-Clause",
  "scripts": {
    "ng": "ng",
    "start": "ng serve",
    "build": "ng build",
    "build:prod": "ng build --configuration production",
    "electron:compile": "tsc -p tsconfig.electron.json",
    "electron:dev": "concurrently -k \"ng serve\" \"wait-on http://localhost:4200 && bun run electron:compile && electron .\"",
    "electron:build": "bun run build:prod && bun run electron:compile && electron-builder",
    "electron:start": "bun run electron:compile && electron .",
    "dev": "bun run start",
    "format": "prettier --write \"**/*.{ts,html,json,md,css}\"",
    "generate-icons": "node scripts/generate-icons.mjs",
    "release:beta": "node scripts/release-beta.mjs"
  },
  "dependencies": {
    "@angular/animations": "^19.2.0",
    "@angular/common": "^19.2.0",
    "@angular/compiler": "^19.2.0",
    "@angular/core": "^19.2.0",
    "@angular/forms": "^19.2.0",
    "@angular/platform-browser": "^19.2.0",
    "@angular/platform-browser-dynamic": "^19.2.0",
    "@angular/router": "^19.2.0",
    "electron-updater": "^6.8.3",
    "lucide-static": "^0.577.0",
    "node-hid": "^3.1.2",
    "rxjs": "~7.8.2",
    "sharp": "^0.33.5",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@angular-devkit/build-angular": "^19.2.0",
    "@angular/cli": "^19.2.0",
    "@angular/compiler-cli": "^19.2.0",
    "@tailwindcss/forms": "^0.5.11",
    "@tailwindcss/postcss": "^4.1.18",
    "@tailwindcss/typography": "^0.5.19",
    "@types/node": "^22.13.0",
    "@types/node-hid": "^1.3.4",
    "autoprefixer": "^10.4.23",
    "concurrently": "^9.2.1",
    "electron": "^35.0.1",
    "electron-builder": "^26.8.1",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.1.18",
    "typescript": "~5.7.2",
    "wait-on": "^9.0.4"
  },
  "engines": {
    "bun": ">=1.0.0"
  },
  "build": {
    "appId": "com.openinput.app",
    "productName": "OpenInput",
    "publish": {
      "provider": "github",
      "owner": "lucatescari",
      "repo": "openinput"
    },
    "directories": {
      "output": "release"
    },
    "files": [
      "dist-electron/**/*",
      "dist/openinput/**/*"
    ],
    "afterSign": "scripts/notarize.mjs",
    "asarUnpack": [
      "**/node_modules/node-hid/**",
      "**/node_modules/sharp/**"
    ],
    "mac": {
      "target": [
        "dmg",
        "zip"
      ],
      "artifactName": "OpenInput-${version}-mac.${ext}",
      "category": "public.app-category.utilities",
      "icon": "build/icon.icns",
      "hardenedRuntime": true,
      "gatekeeperAssess": false,
      "entitlements": "build/entitlements.mac.plist",
      "entitlementsInherit": "build/entitlements.mac.plist"
    },
    "win": {
      "target": "nsis",
      "icon": "build/icon.ico",
      "artifactName": "OpenInput-${version}-win.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "linux": {
      "target": "AppImage",
      "icon": "build"
    }
  },
  "trustedDependencies": [
    "@parcel/watcher"
  ]
}
